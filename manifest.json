{
  "name": "qryma-search",
  "version": "1.0.0",
  "displayName": "Qryma Search",
  "description": "Qryma Ai web search API with Markdown/JSON/Brave formats. Generous free tier covers most daily needs.",
  "author": "Qryma Team",
  "homepage": "",
  "license": "MIT",
  "keywords": [
    "search",
    "web-search",
    "ai",
    "qryma",
    "skills",
    "agent"
  ],
  "category": "search",
  "platforms": [
    "skills.sh",
    "clawhub",
    "skillstore",
    "skillsmp",
    "skill-cn",
    "skillhub.tencent"
  ],
  "entryPoint": {
    "default": "main_claw.py"
  },
  "commands": [
    {
      "name": "search",
      "description": "Search the web with Qryma",
      "usage": "python main_claw.py --query \"your query\"",
      "parameters": [
        {
          "name": "api-key",
          "type": "string",
          "required": false,
          "description": "Qryma API key"
        },
        {
          "name": "query",
          "type": "string",
          "required": true,
          "description": "Search query"
        },
        {
          "name": "max-results",
          "type": "number",
          "default": 5,
          "description": "Maximum number of results"
        },
        {
          "name": "lang",
          "type": "string",
          "default": "en",
          "description": "Language code - [See available languages](https://developers.google.com/custom-search/docs/xml_results_appendices#interfaceLanguages)"
        },
        {
          "name": "start",
          "type": "number",
          "default": 0,
          "description": "Start offset for pagination"
        },
        {
          "name": "safe",
          "type": "boolean",
          "default": false,
          "description": "Enable safe search"
        },
        {
          "name": "detail",
          "type": "boolean",
          "default": false,
          "description": "Enable detailed results"
        },
        {
          "name": "format",
          "type": "enum",
          "options": ["raw", "brave", "md"],
          "default": "md",
          "description": "Output format"
        }
      ]
    }
  ],
  "requirements": {
    "python": ">=3.8",
    "dependencies": [
      {
        "name": "requests",
        "version": ">=2.28.0"
      }
    ]
  },
  "config": {
    "apiKey": {
      "name": "QRYMA_API_KEY",
      "description": "Qryma API key",
      "required": true
    },
    "endpoint": {
      "name": "QRYMA_ENDPOINT",
      "description": "Qryma API endpoint",
      "required": false,
      "default": "https://search.qryma.com/api/web"
    }
  },
  "examples": [
    {
      "name": "Basic search",
      "description": "Search for information",
      "command": "python main_claw.py --query \"how to learn python\" --format md"
    },
    {
      "name": "Detailed search",
      "description": "Get detailed search results",
      "command": "python main_claw.py --query \"explain quantum computing\" --detail --format md"
    }
  ],
  "badges": [
    {
      "name": "Python 3.8+",
      "color": "#3776ab"
    }
  ]
}
